# ─── Contract Addresses ───────────────────────────────────────────────────────
# Fill in after running: forge script script/Deploy.s.sol --broadcast
# Addresses are printed in the deploy output.

VITE_CHESS_PASS_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CHESS_LOBBY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CHINESE_CHESS_ADDRESS=0x0000000000000000000000000000000000000000

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
# Public endpoints work but may be rate-limited.
# For production, replace with your own Alchemy or Infura key.

VITE_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
VITE_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Block number when ChineseChess contract was deployed.
# Used by the leaderboard to avoid scanning from block 0 (which can timeout).
# Fill this in after deployment — it's printed in the forge script output.
VITE_CONTRACT_DEPLOY_BLOCK=0
